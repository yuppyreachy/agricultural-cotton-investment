<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
  <style>
    /* ================= GLOBAL ================= */
    body {
      margin: 0;
      font-family: 'Poppins', sans-serif;
      background: #0a0a0a;
      color: #fff;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    /* ================= LOGIN CARD ================= */
    .login-card {
      background: #1b1b1b;
      padding: 40px;
      border-radius: 12px;
      width: 320px;
      box-shadow: 0 0 20px rgba(255, 215, 0, 0.3);
      text-align: center;
    }

    .login-card h2 {
      color: gold;
      margin-bottom: 20px;
    }

    .login-card input {
      width: 100%;
      padding: 12px;
      margin: 8px 0;
      border: none;
      border-radius: 6px;
      background: #111;
      color: #fff;
    }

    .login-card input::placeholder {
      color: #aaa;
    }

    .login-card button {
      width: 100%;
      padding: 12px;
      margin-top: 12px;
      border: none;
      border-radius: 6px;
      background: gold;
      color: #000;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.3s;
    }

    .login-card button:hover {
      background: #ffdb4d;
    }

    .error-msg {
      color: red;
      margin-bottom: 12px;
    }

  </style>
</head>
<body>

  <div class="login-card">
    <h2>Admin Login</h2>

    <% if (typeof error !== 'undefined') { %>
      <p class="error-msg"><%= error %></p>
    <% } %>

    <form action="/admin/login" method="POST">
  <label>Username</label>
  <input type="text" name="username" required />

  <label>Password</label>
  <input type="password" name="password" required />

  <button type="submit">Login</button>
</form>
  </div>

</body>
</html>